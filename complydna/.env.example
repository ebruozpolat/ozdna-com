# Yerel geliştirme — Docker gerekmez (varsayılan)
QDRANT_PATH=data/qdrant

# Docker veya uzak Qdrant sunucusu için path'i kapatın:
# QDRANT_PATH=
# QDRANT_URL=http://localhost:6333

API_KEY=complydna_sk_test_local
MODEL_VERSION=dev-stub-v1

# On-prem LLM (Ollama / vLLM / OpenAI-compatible)
# LLM_PROVIDER=stub
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=
# LLM_TIMEOUT_SECONDS=120

# PostHog LLM analytics (OpenTelemetry) — optional
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_SERVICE_NAME=complydna
# POSTHOG_DISTINCT_ID=user_123
