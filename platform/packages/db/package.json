{
  "name": "@ozdna/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:push": "OZDNA_DB_PATH=../../data/ozdna.db node --import tsx src/push.ts",
    "db:seed": "OZDNA_DB_PATH=../../data/ozdna.db node --import tsx src/seed.ts"
  },
  "dependencies": {
    "@ozdna/core": "*",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.39.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
